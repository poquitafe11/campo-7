rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regla específica para la colección 'usuarios'
    match /usuarios/{userId} {
      // Permite a un usuario modificar su propio perfil.
      // Permite a un 'Admin' modificar cualquier perfil de usuario.
      allow read, write: if request.auth.uid == userId || get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'Admin';
    }

    // Regla para 'actividades' y otras colecciones
    match /{document=**} {
      // Permite a cualquier usuario autenticado leer y escribir en otras colecciones.
      allow read, write: if request.auth != null;
    }
  }
}
