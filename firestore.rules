rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Reglas para la colección de usuarios
    match /usuarios/{userEmail} {
      // Un usuario puede leer y escribir su propio perfil si su email coincide con el ID del documento
      // O si el usuario autenticado tiene rol de 'Admin'
      allow read, write: if request.auth != null && (
        request.auth.token.email == userEmail || 
        get(/databases/$(database)/documents/usuarios/$(request.auth.token.email)).data.rol == 'Admin'
      );
    }

    // Reglas para el resto de las colecciones (maestros, actividades, etc.)
    match /{collectionName}/{document} {
      // Por ahora, permitimos lectura y escritura a cualquier usuario autenticado 
      // para asegurar que el dashboard y las actividades funcionen.
      allow read, write: if request.auth != null;
    }

    // Permitir subcolecciones de forma recursiva si es necesario
    match /{path=**} {
      allow read, write: if request.auth != null;
    }
  }
}

